# ─────────────────────────────────────────────────────────────
# Integration Academy (.ca) — environment variables
# Copy to .env.local for local dev; set the same keys in your host
# (e.g. Vercel → Project → Settings → Environment Variables) for prod.
# NEVER commit real values. The SERVICE ROLE key is admin-level — keep it secret.
# ─────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for OG tags, robots, sitemap, Stripe redirects.
NEXT_PUBLIC_APP_URL=https://integrationacademy.ca

# Supabase (Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Stripe (Dashboard → Developers → API keys). Use LIVE keys in production.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (Dashboard → Products → each price). LIVE-mode price IDs in prod.
STRIPE_PRICE_STUDENT_MONTHLY=price_xxx
STRIPE_PRICE_STUDENT_ANNUAL=price_xxx
STRIPE_PRICE_TUTOR_MONTHLY=price_xxx
STRIPE_PRICE_TUTOR_ANNUAL=price_xxx

# DeepSeek AI lesson tutor (platform.deepseek.com → API Keys + Billing top-up).
# Server-only — never expose in the browser. Leave unset to disable the tutor API.
DEEPSEEK_API_KEY=sk-xxx
# Optional; default is deepseek-v4-flash (cheapest).
# DEEPSEEK_MODEL=deepseek-v4-flash
