# ─────────────────────────────────────────────────────────────
# Integration Academy (.ca) — High School & University
# Copy this file to ".env.local" and fill in your own values.
# This project uses its OWN Supabase project, separate from the K-8 site.
# ─────────────────────────────────────────────────────────────

# App URL (no trailing slash). Use http://localhost:3000 for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (create a NEW project at https://supabase.com) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STUDENT_MONTHLY=price_...
STRIPE_PRICE_STUDENT_ANNUAL=price_...
STRIPE_PRICE_TUTOR_MONTHLY=price_...
STRIPE_PRICE_TUTOR_ANNUAL=price_...
