\sech{Your Turn --- Show Your Work}
For each question, show all steps clearly in the space provided.

\begin{qbox}{Question 1}
Find the slope of the line through $(0,1)$ and $(2,7)$.\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 2}
State the slope and $y$-intercept of $y=4x-3$.\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 3}
Graph $y=-x+2$ on the grid (plot the $y$-intercept, then use the slope).
\begin{center}\begin{tikzpicture}
\begin{axis}[width=8cm,height=6cm,axis lines=middle,grid=both,grid style={gray!16},xmin=-6,xmax=6,ymin=-6,ymax=6,xtick distance=2,ytick distance=2,tick label style={font=\tiny}]
\end{axis}\end{tikzpicture}\end{center}
\end{qbox}

\begin{qbox}{Question 4}
Rewrite $5x-y=10$ in slope--intercept form.\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 5}
Find the $x$- and $y$-intercepts of $2x+3y=6$.\workspace{2.6cm}
\end{qbox}

\begin{qbox}{Question 6}
Find the equation of the line with slope $3$ through $(0,-2)$.\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 7}
Find the equation of the line through $(1,1)$ and $(3,7)$.\workspace{2.8cm}
\end{qbox}

\begin{qbox}{Question 8}
Find the line parallel to $y=2x+1$ through $(0,4)$.\workspace{2.4cm}
\end{qbox}

\begin{qbox}{Question 9}
Find the line perpendicular to $y=\tfrac12x-3$ through $(2,5)$.\workspace{2.8cm}
\end{qbox}

\begin{qbox}{Question 10}
Is the point $(3,4)$ on the line $y=2x-2$? Justify.\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 11}
For what value of $k$ is the line through $(2,k)$ and $(5,1)$ horizontal?\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 12}
Describe the line through $(-1,2)$ and $(3,2)$ (slope and type).\workspace{2.2cm}
\end{qbox}

\begin{qbox}{Question 13 --- Challenge}
Find the line perpendicular to $3x+y=6$ that passes through that line's $y$-intercept.\workspace{3.2cm}
\end{qbox}

\clearpage
\sech{Question Recap \& Answer Key}

\begin{recapbox}
\begin{multicols}{2}
\small
\begin{enumerate}[leftmargin=*,itemsep=3pt]
  \item Slope through $(0,1)$, $(2,7)$.
  \item Slope and $y$-intercept of $y=4x-3$.
  \item Graph $y=-x+2$.
  \item Rewrite $5x-y=10$ as $y=mx+b$.
  \item Intercepts of $2x+3y=6$.
  \item Line: slope $3$ through $(0,-2)$.
  \item Line through $(1,1)$, $(3,7)$.
  \item Parallel to $y=2x+1$ through $(0,4)$.
  \item Perpendicular to $y=\tfrac12x-3$ through $(2,5)$.
  \item Is $(3,4)$ on $y=2x-2$?
  \item $k$ so $(2,k)$,$(5,1)$ is horizontal.
  \item Line through $(-1,2)$, $(3,2)$.
  \item Perpendicular to $3x+y=6$ through its $y$-intercept.
\end{enumerate}
\end{multicols}
\end{recapbox}

\begin{keybox}
\begin{multicols}{2}
\small
\begin{enumerate}[leftmargin=*,itemsep=3pt]
  \item $m=\dfrac{7-1}{2-0}=3$.
  \item slope $4$, $y$-intercept $(0,-3)$.
  \item Line through $(0,2)$ with slope $-1$ (down $1$, right $1$).
  \item $y=5x-10$.
  \item $x$-intercept $(3,0)$, $y$-intercept $(0,2)$.
  \item $y=3x-2$.
  \item $m=3$, $y=3x-2$.
  \item $y=2x+4$.
  \item slope $-2$, $y=-2x+9$.
  \item $2(3)-2=4$ $\checkmark$ --- yes, it is on the line.
  \item $k=1$ (equal $y$-values give slope $0$).
  \item slope $0$; a horizontal line $y=2$.
  \item Intercept $(0,6)$; slope $\tfrac13$, so $y=\tfrac13x+6$.
\end{enumerate}
\end{multicols}
\end{keybox}

