\begin{document}

\begin{center}
{\LARGE\bfseries\color{titleblue}Worksheet 1.1 --- Review of Linear Relations}\\[2pt]
{\small Grade 10 Academic (MPM2D) \textperiodcentered{} Unit 1: Linear Systems}
\end{center}

\begin{ideabox}
A \textbf{linear relation} graphs as a straight line. Master these before solving systems of lines.
\begin{itemize}[leftmargin=*,itemsep=2pt]
  \item \textbf{Slope} $m=\dfrac{\text{rise}}{\text{run}}=\dfrac{y_2-y_1}{x_2-x_1}$ --- the constant rate of change. Positive rises, negative falls, $0$ is horizontal, and a vertical line has an \emph{undefined} slope.
  \item \textbf{Intercepts:} the $y$-intercept is where $x=0$; the $x$-intercept (the zero) is where $y=0$.
  \item \textbf{Three forms:} slope--intercept $y=mx+b$ (best for graphing), standard $Ax+By=C$ (best for intercepts and elimination), and point--slope $y-y_1=m(x-x_1)$ (best for building an equation).
  \item \textbf{Graphing} $y=mx+b$: plot $b$, then step by the slope as $\tfrac{\text{rise}}{\text{run}}$.
  \item \textbf{Parallel} lines have equal slopes; \textbf{perpendicular} slopes are negative reciprocals ($m_1m_2=-1$).
\end{itemize}
\end{ideabox}

\sech{Worked Examples}

\begin{example}{Example 1 --- Slope from two points}
Find the slope of the line through $(2,3)$ and $(6,11)$.
\soln $m=\dfrac{11-3}{6-2}=\dfrac{8}{4}=2.$ The line rises $2$ for every $1$ across.
\end{example}

\begin{example}{Example 2 --- Read slope and intercept}
State the slope and $y$-intercept of $y=-3x+5$.
\soln In $y=mx+b$, $m=-3$ and $b=5$, so the slope is $-3$ and the $y$-intercept is $(0,5)$.
\end{example}

\begin{example}{Example 3 --- Graphing a line}
Graph $y=2x-1$.
\soln Start at the $y$-intercept $(0,-1)$, then go up $2$, right $1$ to $(1,1)$.
\plot{-5}{5}{-5}{5}{\addplot[exblue,very thick,domain=-2:3,samples=2]{2*x-1};
\addplot[mark=*,only marks,black]coordinates{(0,-1)(1,1)};}
\end{example}

\begin{example}{Example 4 --- Standard form and intercepts}
Rewrite $3x+2y=12$ in slope--intercept form and find both intercepts.
\soln $2y=-3x+12\Rightarrow y=-\tfrac32x+6$, so $m=-\tfrac32$. Set $y=0$: $x=4$; set $x=0$: $y=6$. Intercepts $(4,0)$ and $(0,6)$.
\plot{-2}{8}{-2}{8}{\addplot[exblue,very thick,domain=-1:6,samples=2]{-1.5*x+6};
\addplot[mark=*,only marks,black]coordinates{(4,0)(0,6)};}
\end{example}

\begin{example}{Example 5 --- Equation from a point and slope}
Find the line with slope $-2$ through $(3,1)$.
\soln Point--slope: $y-1=-2(x-3)\Rightarrow y-1=-2x+6\Rightarrow y=-2x+7.$
\end{example}

\begin{example}{Example 6 --- Equation from two points}
Find the line through $(1,2)$ and $(4,11)$.
\soln $m=\dfrac{11-2}{4-1}=3$. Then $y-2=3(x-1)\Rightarrow y=3x-1.$
\end{example}

\begin{example}{Example 7 --- Parallel line}
Find the line parallel to $y=\tfrac12x-4$ through $(2,5)$.
\soln Parallel $\Rightarrow$ same slope $\tfrac12$. $y-5=\tfrac12(x-2)\Rightarrow y=\tfrac12x+4.$
\plot{-5}{7}{-5}{7}{\addplot[gray,thick,domain=-5:7,samples=2]{0.5*x-4};
\addplot[exblue,very thick,domain=-5:7,samples=2]{0.5*x+4};
\addplot[mark=*,only marks,black]coordinates{(2,5)};}
\end{example}

\begin{example}{Example 8 --- Perpendicular line}
Find the line perpendicular to $y=-2x+1$ through $(4,3)$.
\soln Perpendicular slope $=$ negative reciprocal of $-2=\tfrac12$. $y-3=\tfrac12(x-4)\Rightarrow y=\tfrac12x+1.$
\end{example}

\begin{example}{Example 9 --- Putting it together (harder)}
Find the line through $(-2,5)$ perpendicular to $2x-y=3$, then find its $x$-intercept.
\soln Rewrite $2x-y=3$ as $y=2x-3$ (slope $2$); perpendicular slope $=-\tfrac12$. Through $(-2,5)$: $y-5=-\tfrac12(x+2)\Rightarrow y=-\tfrac12x+4$. Set $y=0$: $0=-\tfrac12x+4\Rightarrow x=8$. The $x$-intercept is $(8,0)$.
\plot{-6}{10}{-6}{8}{\addplot[gray,thick,domain=-2:5,samples=2]{2*x-3};
\addplot[exblue,very thick,domain=-6:10,samples=2]{-0.5*x+4};
\addplot[mark=*,only marks,black]coordinates{(-2,5)(8,0)};}
\end{example}

